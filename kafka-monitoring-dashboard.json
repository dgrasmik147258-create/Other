{
  "dashboard": {
    "id": null,
    "title": "Kafka Monitoring",
    "tags": ["kafka", "monitoring", "performance"],
    "style": "dark",
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Оборудование",
        "type": "row",
        "collapsed": false,
        "panels": []
      },
      {
        "id": 2,
        "title": "График нагрузки процессора",
        "type": "graph",
        "targets": [
          {
            "expr": "100 - (avg by (instance) (irate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
            "legendFormat": "CPU Load - {{instance}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "yAxes": [
          {"label": "CPU Usage %", "min": 0, "max": 100}
        ],
        "thresholds": [
          {"color": "green", "value": null},
          {"color": "yellow", "value": 70},
          {"color": "red", "value": 90}
        ]
      },
      {
        "id": 3,
        "title": "Текущая нагрузка процессора",
        "type": "stat",
        "targets": [
          {
            "expr": "100 - (avg by (instance) (irate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
            "legendFormat": "{{instance}}"
          }
        ],
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 70},
                {"color": "red", "value": 90}
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "График нагрузки диска",
        "type": "graph",
        "targets": [
          {
            "expr": "100 - ((node_filesystem_avail_bytes{mountpoint=\"/\"} * 100) / node_filesystem_size_bytes{mountpoint=\"/\"})",
            "legendFormat": "Disk Usage - {{instance}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
        "yAxes": [
          {"label": "Disk Usage %", "min": 0, "max": 100}
        ],
        "thresholds": [
          {"color": "green", "value": null},
          {"color": "yellow", "value": 80},
          {"color": "red", "value": 90}
        ]
      },
      {
        "id": 5,
        "title": "График нагрузки ОЗУ",
        "type": "graph",
        "targets": [
          {
            "expr": "100 - ((node_memory_MemAvailable_bytes * 100) / node_memory_MemTotal_bytes)",
            "legendFormat": "RAM Usage - {{instance}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
        "yAxes": [
          {"label": "RAM Usage %", "min": 0, "max": 100}
        ],
        "thresholds": [
          {"color": "green", "value": null},
          {"color": "yellow", "value": 80},
          {"color": "red", "value": 90}
        ]
      },
      {
        "id": 6,
        "title": "Текущая нагрузка ОЗУ",
        "type": "stat",
        "targets": [
          {
            "expr": "100 - ((node_memory_MemAvailable_bytes * 100) / node_memory_MemTotal_bytes)",
            "legendFormat": "{{instance}}"
          }
        ],
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 16},
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 80},
                {"color": "red", "value": 90}
              ]
            }
          }
        }
      },
      {
        "id": 7,
        "title": "Компоненты кластера Kafka",
        "type": "row",
        "collapsed": false,
        "panels": []
      },
      {
        "id": 8,
        "title": "Доступность кластера",
        "type": "stat",
        "targets": [
          {
            "expr": "kafka_server_replicamanager_underreplicatedpartitions",
            "legendFormat": "Under Replicated Partitions"
          }
        ],
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 20},
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "red", "value": 1}
              ]
            }
          }
        }
      },
      {
        "id": 9,
        "title": "JVM Threads State",
        "type": "graph",
        "targets": [
          {
            "expr": "jvm_threads_state",
            "legendFormat": "{{state}} - {{instance}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 6, "y": 20},
        "yAxes": [
          {"label": "Thread Count"}
        ]
      },
      {
        "id": 10,
        "title": "Request Total Time (ms)",
        "type": "graph",
        "targets": [
          {
            "expr": "kafka_network_requestmetrics_totaltimems",
            "legendFormat": "{{instance}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 18, "y": 20},
        "yAxes": [
          {"label": "Time (ms)"}
        ]
      },
      {
        "id": 11,
        "title": "Кол-во текущих подключений",
        "type": "stat",
        "targets": [
          {
            "expr": "kafka_server_socket_server_metrics_connection_count",
            "legendFormat": "{{instance}}"
          }
        ],
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 24},
        "fieldConfig": {
          "defaults": {
            "unit": "short"
          }
        }
      },
      {
        "id": 12,
        "title": "Requests Per Second",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(kafka_network_requestmetrics_requests_total[5m])",
            "legendFormat": "{{instance}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 6, "y": 24},
        "yAxes": [
          {"label": "Requests/sec"}
        ]
      },
      {
        "id": 13,
        "title": "Partition Count",
        "type": "stat",
        "targets": [
          {
            "expr": "kafka_controller_kafkacontroller_partitioncount",
            "legendFormat": "{{instance}}"
          }
        ],
        "gridPos": {"h": 4, "w": 6, "x": 18, "y": 24},
        "fieldConfig": {
          "defaults": {
            "unit": "short"
          }
        }
      },
      {
        "id": 14,
        "title": "Active Broker Count",
        "type": "stat",
        "targets": [
          {
            "expr": "kafka_controller_kafkacontroller_activebrokercount",
            "legendFormat": "{{instance}}"
          }
        ],
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 28},
        "fieldConfig": {
          "defaults": {
            "unit": "short"
          }
        }
      },
      {
        "id": 15,
        "title": "Local Time (ms)",
        "type": "graph",
        "targets": [
          {
            "expr": "kafka_network_requestmetrics_localtimems",
            "legendFormat": "{{instance}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 6, "y": 28},
        "yAxes": [
          {"label": "Time (ms)"}
        ]
      },
      {
        "id": 16,
        "title": "Request Queue Time (ms)",
        "type": "graph",
        "targets": [
          {
            "expr": "kafka_network_requestmetrics_requestqueuetimems",
            "legendFormat": "{{instance}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 18, "y": 28},
        "yAxes": [
          {"label": "Time (ms)"}
        ]
      },
      {
        "id": 17,
        "title": "Failed Producer Requests",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(kafka_server_brokertopicmetrics_failedproducerrequests_total[5m])",
            "legendFormat": "{{topic}} - {{instance}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 32},
        "yAxes": [
          {"label": "Failed Requests/sec"}
        ]
      },
      {
        "id": 18,
        "title": "Under Replicated Partitions",
        "type": "graph",
        "targets": [
          {
            "expr": "kafka_server_replicamanager_underreplicatedpartitions",
            "legendFormat": "{{instance}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 32},
        "yAxes": [
          {"label": "Partition Count"}
        ]
      },
      {
        "id": 19,
        "title": "Очереди",
        "type": "row",
        "collapsed": false,
        "panels": []
      },
      {
        "id": 20,
        "title": "Размер очереди",
        "type": "stat",
        "targets": [
          {
            "expr": "kafka_log_logendoffset - kafka_log_logstartoffset",
            "legendFormat": "{{topic}} - {{partition}}"
          }
        ],
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 36},
        "fieldConfig": {
          "defaults": {
            "unit": "short"
          }
        }
      },
      {
        "id": 21,
        "title": "Кол-во partition per topic",
        "type": "table",
        "targets": [
          {
            "expr": "count by (topic) (kafka_log_logendoffset)",
            "format": "table",
            "instant": true
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 6, "y": 36},
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": {
                "Time": true
              },
              "indexByName": {},
              "renameByName": {
                "topic": "Topic",
                "Value": "Partition Count"
              }
            }
          }
        ]
      },
      {
        "id": 22,
        "title": "Динамика лага",
        "type": "graph",
        "targets": [
          {
            "expr": "kafka_consumer_group_max_lag",
            "legendFormat": "{{group}} - {{topic}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 18, "y": 36},
        "yAxes": [
          {"label": "Lag"}
        ],
        "thresholds": [
          {"color": "green", "value": null},
          {"color": "yellow", "value": 50},
          {"color": "red", "value": 100}
        ]
      },
      {
        "id": 23,
        "title": "Очереди без сообщений за последний 24 часа",
        "type": "table",
        "targets": [
          {
            "expr": "kafka_log_logendoffset - kafka_log_logstartoffset",
            "format": "table",
            "instant": true
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 40},
        "transformations": [
          {
            "id": "filterFieldsByName",
            "options": {
              "include": {
                "names": ["topic", "partition", "Value"]
              }
            }
          },
          {
            "id": "organize",
            "options": {
              "excludeByName": {
                "Time": true
              },
              "indexByName": {},
              "renameByName": {
                "topic": "Topic",
                "partition": "Partition",
                "Value": "Message Count"
              }
            }
          }
        ]
      },
      {
        "id": 24,
        "title": "Кол-во consumer per topic",
        "type": "table",
        "targets": [
          {
            "expr": "count by (topic) (kafka_consumer_group_members)",
            "format": "table",
            "instant": true
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 40},
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": {
                "Time": true
              },
              "indexByName": {},
              "renameByName": {
                "topic": "Topic",
                "Value": "Consumer Count"
              }
            }
          }
        ]
      },
      {
        "id": 25,
        "title": "Общее состояние лага",
        "type": "stat",
        "targets": [
          {
            "expr": "max(kafka_consumer_group_max_lag)",
            "legendFormat": "Max Lag"
          }
        ],
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 44},
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 50},
                {"color": "red", "value": 100}
              ]
            }
          }
        }
      },
      {
        "id": 26,
        "title": "Consumer",
        "type": "row",
        "collapsed": false,
        "panels": []
      },
      {
        "id": 27,
        "title": "Bytes Consumed Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(kafka_consumer_fetch_manager_metrics_bytes_consumed_total[5m])",
            "legendFormat": "{{client_id}} - {{instance}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 48},
        "yAxes": [
          {"label": "Bytes/sec"}
        ]
      },
      {
        "id": 28,
        "title": "Rebalance Time Max",
        "type": "graph",
        "targets": [
          {
            "expr": "kafka_consumer_group_rebalance_time_max",
            "legendFormat": "{{group}} - {{instance}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 48},
        "yAxes": [
          {"label": "Time (ms)"}
        ]
      },
      {
        "id": 29,
        "title": "Скорость обработки сообщений",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(kafka_consumer_fetch_manager_metrics_records_consumed_total[5m])",
            "legendFormat": "{{client_id}} - {{instance}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 52},
        "yAxes": [
          {"label": "Messages/sec"}
        ]
      },
      {
        "id": 30,
        "title": "Доступность",
        "type": "stat",
        "targets": [
          {
            "expr": "up{job=\"kafka\"}",
            "legendFormat": "{{instance}}"
          }
        ],
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 52},
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "steps": [
                {"color": "red", "value": null},
                {"color": "green", "value": 1}
              ]
            }
          }
        }
      },
      {
        "id": 31,
        "title": "Динамика балансировки",
        "type": "graph",
        "targets": [
          {
            "expr": "kafka_consumer_group_rebalance_rate",
            "legendFormat": "{{group}} - {{instance}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 18, "y": 52},
        "yAxes": [
          {"label": "Rebalances/sec"}
        ]
      }
    ],
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "timepicker": {
      "refresh_intervals": [
        "5s",
        "10s",
        "30s",
        "1m",
        "5m",
        "15m",
        "30m",
        "1h",
        "2h",
        "1d"
      ]
    },
    "templating": {
      "list": []
    },
    "annotations": {
      "list": []
    },
    "refresh": "30s",
    "schemaVersion": 27,
    "version": 1,
    "links": [],
    "gnetId": null,
    "uid": "kafka-monitoring"
  }
}